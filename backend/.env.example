# Configuracion de conexion a la base de datos
# Copiar este archivo como .env y rellenar con tus credenciales de Supabase
#
# IMPORTANTE: Usar el host del Session Pooler de Supabase.
# Se encuentra en: Project Settings → Database → Connect → Session mode
DB_HOST=tu-proyecto.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.tu-project-id
DB_PASSWORD=tu-password
PORT=3000
